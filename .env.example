# Phase: "testnet" or "production"
# Default when unset is production (mainnet); .env.production sets production for release builds.
# testnet  = DFlow dev endpoints + Solana devnet (free test tokens)
# production = DFlow prod endpoints + Solana mainnet (real money)
VITE_PHASE=testnet

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback still supported:
VITE_SUPABASE_ANON_KEY=

# Solana RPC (optional — overrides per-phase default)
VITE_SOLANA_RPC_URL=
VITE_MAINNET_RPC_URL=

# Cusp Protocol — on-chain addresses (devnet)
VITE_CUSDC_MINT=
VITE_VAULT_USDC_ACCOUNT=
VITE_VAULT_PUBLIC_KEY=
VITE_TEST_USDC_MINT=
VITE_VAULT_PROGRAM_ID=
VITE_LEVERAGE_PROGRAM_ID=

# DFlow Production API (server-side only — never prefix with VITE_)
DFLOW_API_KEY=your-dflow-api-key
VITE_DFLOW_WS_URL=wss://prediction-markets-api.dflow.net/api/v1/ws

# Solflare

# Local dev only — skips invite gate; use in .env.local, never enable on prod/preview CI
# VITE_SKIP_INVITE_GATE=true
