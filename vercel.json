{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/dflow-trade/:path*", "destination": "/api/dflow-trade/:path*" },
    { "source": "/api/dflow/:path*", "destination": "/api/dflow/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
